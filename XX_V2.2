local noclipEnabled = false

UtilTab:CreateSection("🚶  Movement")

local function setCollisions(state)
    local char = LocalPlayer.Character
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = state
            end
        end
    end
end

UtilTab:CreateToggle({
    Name         = "Noclip  [E]",
    CurrentValue = false,
    Flag         = "NOCLIP",
    Callback     = function(val)
        noclipEnabled = val
        if not val then
            setCollisions(true)
        end
    end,
})

RunService.Stepped:Connect(function()
    if noclipEnabled then
        setCollisions(false)
    end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.E then
        noclipEnabled = not noclipEnabled
        Rayfield:SetToggle("NOCLIP", noclipEnabled)
        if not noclipEnabled then
            setCollisions(true)
        end
        Rayfield:Notify({
            Title   = "Noclip",
            Content = noclipEnabled and "Enabled — walk through walls" or "Disabled",
            Duration = 2,
        })
    end
end)

LocalPlayer.CharacterAdded:Connect(function(char)
    if noclipEnabled then
        setCollisions(false)
    end
end)

-- ══════════════════════════════════════════
--  DASH FORWARD  [4]
-- ══════════════════════════════════════════
local DASH_DISTANCE = 15
local dashCooldown  = false
local DASH_COOLDOWN = 0.3

local function DashForward()
    if dashCooldown then return end
    local char     = LocalPlayer.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not rootPart or not humanoid then return end
    if humanoid.Health <= 0 then return end

    local look        = rootPart.CFrame.LookVector
    local flatForward = Vector3.new(look.X, 0, look.Z).Unit
    local newPos      = rootPart.Position + (flatForward * DASH_DISTANCE)

    rootPart.CFrame = CFrame.new(newPos, newPos + flatForward)

    dashCooldown = true
    task.delay(DASH_COOLDOWN, function()
        dashCooldown = false
    end)

    Rayfield:Notify({
        Title    = "Dash",
        Content  = "Dashed forward " .. DASH_DISTANCE .. " studs",
        Duration = 1,
    })
end

UtilTab:CreateSection("💨  Dash")

UtilTab:CreateButton({
    Name     = "Dash Forward  [4]",
    Callback = DashForward,
})

UtilTab:CreateSlider({
    Name           = "Dash Distance",
    Range          = {5, 60},
    Increment      = 5,
    Suffix         = " studs",
    CurrentValue   = 15,
    Flag           = "DashDist",
    Callback       = function(val)
        DASH_DISTANCE = val
    end,
})

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.Four then
        DashForward()
    end
end)

