local NV_COLOR        = Color3.fromRGB(220, 255, 220)

-- ══════════════════════════════════════════
--  ESP
-- ══════════════════════════════════════════
local function removeESP(player)
    if espObjects[player] then
        if espObjects[player].highlight then espObjects[player].highlight:Destroy() end
        if espObjects[player].billboard then espObjects[player].billboard:Destroy() end
        espObjects[player] = nil
    end
end

local function addESP(player)
    if player == LocalPlayer then return end
    removeESP(player)
    local char = player.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end

    local hl = Instance.new("Highlight")
    hl.Adornee             = char
    hl.FillColor           = HIGHLIGHT_COLOR
    hl.OutlineColor        = Color3.fromRGB(255, 255, 255)
    hl.FillTransparency    = 0.4
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent              = workspace

    local bb = Instance.new("BillboardGui")
    bb.Size        = UDim2.new(0, 80, 0, 22)
    bb.StudsOffset = Vector3.new(0, 3.2, 0)
    bb.Adornee     = head
    bb.AlwaysOnTop = true
    bb.Parent      = workspace

    local nameTag = Instance.new("TextLabel")
    nameTag.Size                     = UDim2.new(1, 0, 1, 0)
    nameTag.BackgroundColor3       = Color3.fromRGB(10, 12, 22)
    nameTag.BackgroundTransparency = 0.3
    nameTag.TextColor3             = HIGHLIGHT_COLOR
    nameTag.Font                   = Enum.Font.RobotoMono
    nameTag.TextSize               = 12
    nameTag.Text                   = player.Name
    nameTag.TextScaled             = true
    nameTag.Parent                 = bb
    Instance.new("UICorner", nameTag).CornerRadius = UDim.new(0, 4)

    espObjects[player] = {highlight = hl, billboard = bb}
end

local function refreshESP()
    for p in pairs(espObjects) do removeESP(p) end
    if not espEnabled then return end
    for _, p in ipairs(Players:GetPlayers()) do addESP(p) end
end

Players.PlayerAdded:Connect(function(p)
    if espEnabled then
        p.CharacterAdded:Connect(function() task.wait(0.5) addESP(p) end)
        task.wait(0.5) addESP(p)
    end
end)
Players.PlayerRemoving:Connect(removeESP)
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        p.CharacterAdded:Connect(function()
            if espEnabled then task.wait(0.5) addESP(p) end
        end)
    end
end

-- ══════════════════════════════════════════
--  NIGHT VISION
-- ══════════════════════════════════════════
local nvPart1, nvPart2

local function enableNV()
    if nvPart1 then nvPart1:Destroy() nvPart1 = nil end
    if nvPart2 then nvPart2:Destroy() nvPart2 = nil end

    local function makeLight(name, brightness)
        local p = Instance.new("Part")
        p.Size = Vector3.new(0.1,0.1,0.1)
        p.CanCollide = false p.Anchored = true
        p.Transparency = 1 p.CastShadow = false
        p.Name = name p.Parent = workspace
        local l = Instance.new("PointLight")
        l.Range = 1000 l.Brightness = brightness
        l.Color = NV_COLOR l.Shadows = false l.Parent = p
        return p
    end

    nvPart1 = makeLight("NV_Primary", 10)
    nvPart2 = makeLight("NV_Fill",    8)

    RunService:BindToRenderStep("NVFollow", Enum.RenderPriority.Camera.Value + 1, function()
        if nvPart1 then nvPart1.CFrame = Camera.CFrame end
        if nvPart2 then nvPart2.CFrame = Camera.CFrame * CFrame.new(0, 4, -6) end
    end)
end

local function disableNV()
    RunService:UnbindFromRenderStep("NVFollow")
    if nvPart1 then nvPart1:Destroy() nvPart1 = nil end
    if nvPart2 then nvPart2:Destroy() nvPart2 = nil end
end

-- ══════════════════════════════════════════
--  SPECTATE
-- ══════════════════════════════════════════
local function stopSpectate()
    RunService:UnbindFromRenderStep("SpecCam")
    Camera.CameraType = Enum.CameraType.Custom
    if LocalPlayer.Character then
        Camera.CameraSubject = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    end
    spectateTarget = nil
end

local function startSpectate(player)
    if not spectateEnabled or player == LocalPlayer then return end
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    spectateTarget    = player
    Camera.CameraType = Enum.CameraType.Scriptable
    RunService:BindToRenderStep("SpecCam", Enum.RenderPriority.Camera.Value + 1, function()
        local c = spectateTarget and spectateTarget.Character
        local h = c and c:FindFirstChild("HumanoidRootPart")
        if h then
            Camera.CFrame = CFrame.new(h.Position + Vector3.new(0,3,8), h.Position)
        end
    end)
end

-- ══════════════════════════════════════════
--  FREE CAM
-- ══════════════════════════════════════════
local freeCamPart, fcMouseConn
local fcYaw, fcPitch = 0, 0
local FC_SPEED       = 1
local FC_SENS        = 0.3

local function enableFreeCam()
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hum then hum.WalkSpeed = 0 hum.JumpHeight = 0 end
        if hrp then hrp.Anchored = true end
    end

    local camCF   = Camera.CFrame
    local lookVec = camCF.LookVector
    fcYaw   = math.deg(math.atan2(-lookVec.X, -lookVec.Z))
    fcPitch = math.clamp(math.deg(math.asin(lookVec.Y)), -89, 89)

    local part = Instance.new("Part")
    part.Size = Vector3.new(0.1,0.1,0.1) part.CanCollide = false
    part.Anchored = true part.Transparency = 1
    part.CastShadow = false part.CFrame = camCF part.Parent = workspace
    freeCamPart = part

    Camera.CameraType = Enum.CameraType.Scriptable
    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

    fcMouseConn = UserInputService.InputChanged:Connect(function(input)
        if not freeCamEnabled then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            fcYaw   = fcYaw   - input.Delta.X * FC_SENS
            fcPitch = math.clamp(fcPitch - input.Delta.Y * FC_SENS, -89, 89)
        end
    end)

    RunService:BindToRenderStep("FreeCam", Enum.RenderPriority.Camera.Value + 1, function()
        if not freeCamEnabled or not freeCamPart then return end
        local rot   = CFrame.Angles(0, math.rad(fcYaw), 0) * CFrame.Angles(math.rad(fcPitch), 0, 0)
        local shift = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
        local spd   = shift and FC_SPEED * 3 or FC_SPEED
        local move  = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + rot.LookVector  * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - rot.LookVector  * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - rot.RightVector * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + rot.RightVector * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then move = move + Vector3.new(0, spd, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then move = move - Vector3.new(0, spd, 0) end
        freeCamPart.CFrame = CFrame.new(freeCamPart.Position + move) * rot
        Camera.CFrame      = freeCamPart.CFrame
    end)
end

local function disableFreeCam()
    RunService:UnbindFromRenderStep("FreeCam")
    if fcMouseConn then fcMouseConn:Disconnect() fcMouseConn = nil end
    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    if freeCamPart then freeCamPart:Destroy() freeCamPart = nil end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hum then hum.WalkSpeed = 16 hum.JumpHeight = 7.2 end
        if hrp then hrp.Anchored = false end
    end
    Camera.CameraType = Enum.CameraType.Custom
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then Camera.CameraSubject = hum end
    end
end

-- ══════════════════════════════════════════
--  FPS BOOST
-- ══════════════════════════════════════════
local function runFPSBoost()
    local g = game
    local l = g.Lighting
    local t = workspace.Terrain
    t.WaterWaveSize = 0 t.WaterWaveSpeed = 0
    t.WaterReflectance = 0 t.WaterTransparency = 0
    l.GlobalShadows = false l.FogEnd = 9e9 l.Brightness = 0
    settings().Rendering.QualityLevel = "Level01"
    for _, v in pairs(g:GetDescendants()) do
        if v:IsA("Part") or v:IsA("Union") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") then
            v.Material = Enum.Material.Plastic v.Reflectance = 0
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
            v.Lifetime = NumberRange.new(0)
        elseif v:IsA("Explosion") then
            v.BlastPressure = 1 v.BlastRadius = 1
        elseif v:IsA("Fire") or v:IsA("SpotLight") or v:IsA("Smoke") then
            v.Enabled = false
        elseif v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic v.Reflectance = 0
        end
    end
    for _, e in pairs(l:GetChildren()) do
        if e:IsA("BlurEffect") or e:IsA("SunRaysEffect") or e:IsA("ColorCorrectionEffect")
            or e:IsA("BloomEffect") or e:IsA("DepthOfFieldEffect") then
            e.Enabled = false
        end
    end
end

-- ══════════════════════════════════════════
--  LIVE FPS LABEL  (shown in Utility tab)
-- ══════════════════════════════════════════
local fpsSamples = {}

local fpsSection = UtilTab:CreateSection("📊  Performance")
local fpsLabel = UtilTab:CreateLabel("FPS: calculating...")

RunService.RenderStepped:Connect(function(dt)
    table.insert(fpsSamples, 1 / dt)
    if #fpsSamples > 30 then table.remove(fpsSamples, 1) end
    local sum = 0
    for _, v in ipairs(fpsSamples) do sum = sum + v end
    local avg = math.floor(sum / #fpsSamples)
    local tag = avg >= 55 and "🟢" or avg >= 30 and "🟡" or "🔴"
    fpsLabel:Set("FPS: " .. tag .. " " .. avg)
end)

-- ══════════════════════════════════════════
--  NO FALL DAMAGE & HIGH MASS LOGIC (Updated to 75,000)
-- ══════════════════════════════════════════
local noFallDamageActive = false
local highMassActive = false
local lastHealth = 100

local function updateCharPhysicalProperties(char)
    if not char then return end
    for _, descendant in ipairs(char:GetDescendants()) do
        if descendant:IsA("BasePart") then
            if highMassActive then
                -- Pushed to 75,000 mass limit
                descendant.CustomPhysicalProperties = PhysicalProperties.new(75000, 0.3, 0.5)
            else
                descendant.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5)
            end
        end
    end
end

LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1.5)
    local hum = char:WaitForChild("Humanoid")
    
    lastHealth = hum.Health
    hum.HealthChanged:Connect(function(health)
        if noFallDamageActive and health < lastHealth then
            hum.Health = lastHealth
        else
            lastHealth = health
        end
    end)
    
    char.DescendantAdded:Connect(function(descendant)
        if highMassActive and descendant:IsA("BasePart") then
            descendant.CustomPhysicalProperties = PhysicalProperties.new(75000, 0.3, 0.5)
        end
    end)

    if highMassActive then
        updateCharPhysicalProperties(char)
    end
end)

if LocalPlayer.Character then
    LocalPlayer.Character.DescendantAdded:Connect(function(descendant)
        if highMassActive and descendant:IsA("BasePart") then
            descendant.CustomPhysicalProperties = PhysicalProperties.new(75000, 0.3, 0.5)
        end
    end)

    local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        lastHealth = hum.Health
        hum.HealthChanged:Connect(function(health)
            if noFallDamageActive and health < lastHealth then
                hum.Health = lastHealth
            else
                lastHealth = health
            end
        end)
    end
end

