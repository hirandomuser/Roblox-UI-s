-- ══════════════════════════════════════════
--  KEYBOARD SHORTCUTS
-- ══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

    if input.KeyCode == Enum.KeyCode.Zero then
        espEnabled = not espEnabled
        Rayfield:SetToggle("ESP", espEnabled)
        refreshESP()

    elseif input.KeyCode == Enum.KeyCode.Nine then
        nvEnabled = not nvEnabled
        Rayfield:SetToggle("NV", nvEnabled)
        if nvEnabled then enableNV() else disableNV() end

    elseif input.KeyCode == Enum.KeyCode.Eight then
        spectateEnabled = not spectateEnabled
        Rayfield:SetToggle("SPEC", spectateEnabled)
        if not spectateEnabled then stopSpectate() end

    elseif input.KeyCode == Enum.KeyCode.Seven then
        freeCamEnabled = not freeCamEnabled
        Rayfield:SetToggle("FC", freeCamEnabled)
        if freeCamEnabled then enableFreeCam() else disableFreeCam() end

    elseif input.KeyCode == Enum.KeyCode.Six then
        fpsBoostActive = not fpsBoostActive
        Rayfield:SetToggle("FPSBOOST", fpsBoostActive)
        if fpsBoostActive then runFPSBoost() end

    elseif input.KeyCode == Enum.KeyCode.RightShift then
        Rayfield:Toggle()
    end
end)

Players.PlayerAdded:Connect(function()
    if spectateEnabled then return end
end)
Players.PlayerRemoving:Connect(function(p)
    if spectateTarget == p then stopSpectate() end
end)

